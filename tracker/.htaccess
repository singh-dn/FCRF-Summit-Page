# ================================================================
#  tracker/.htaccess
#  Keeps .php extensions, blocks sensitive files, allows CORS
# ================================================================

Options -Indexes

# ── Stop root rewrite rules from running inside here ─────────────
<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>

# ── Block direct access to config & schema ───────────────────────
<FilesMatch "^(config\.php|schema\.sql|README\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── CORS for track.php (called from other domains) ───────────────
<Files "track.php">
    <IfModule mod_headers.c>
        Header always set Access-Control-Allow-Origin  "*"
        Header always set Access-Control-Allow-Methods "POST, OPTIONS"
        Header always set Access-Control-Allow-Headers "Content-Type, X-Tracker-Key"
    </IfModule>
</Files>

# ── No caching on tracker PHP responses ──────────────────────────
<FilesMatch "\.php$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "no-store, no-cache, must-revalidate"
    </IfModule>
</FilesMatch>
