RewriteEngine On

# ---------------------------------
# 1. Force HTTPS
# ---------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---------------------------------
# 2. Redirect index.html or index.php to /
# ---------------------------------
RewriteCond %{THE_REQUEST} \s/+index\.(html|php) [NC]
RewriteRule ^index\.(html|php)$ / [R=301,L]

# ---------------------------------
# 3. Redirect .html or .php URLs to clean URLs
# ---------------------------------
RewriteCond %{THE_REQUEST} \s/+(.*)\.(html|php) [NC]
RewriteRule ^ %1 [R=301,L]

# ---------------------------------
# 4. Handle Clean URLs (IMPORTANT FOR YOUR FILES)
# ---------------------------------

# About page
RewriteRule ^about-us/?$ about-us.html [L]

# Apply speaker (PHP)
RewriteRule ^apply-as-a-speaker/?$ apply-as-a-speaker.php [L]

# ---------------------------------
# 5. Serve PHP files internally
# ---------------------------------
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# ---------------------------------
# 6. Serve HTML files internally
# ---------------------------------
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ---------------------------------
# 7. Security: Disable directory listing
# ---------------------------------
Options -Indexes