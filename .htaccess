RewriteEngine On

# ---------------------------------
# 1. Force HTTPS
# ---------------------------------
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---------------------------------
# 2. Set default index
# ---------------------------------
DirectoryIndex index.html

# ---------------------------------
# 3. Remove .html extension from URL
# (redirect /about-us.html → /about-us)
# ---------------------------------
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]

# ---------------------------------
# 4. Internal rewrite (clean URL → file)
# (/about-us → about-us.html)
# ---------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ---------------------------------
# 5. Handle PHP clean URLs
# (/apply-as-a-speaker → apply-as-a-speaker.php)
# ---------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# ---------------------------------
# 6. Prevent direct access to .html (optional SEO)
# ---------------------------------
#RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
#RewriteRule ^ /%1 [R=301,L]

# ---------------------------------
# 7. Disable directory listing (security)
# ---------------------------------
Options -Indexes