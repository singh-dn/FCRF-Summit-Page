RewriteEngine On

# FORCE HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# TRACKER FOLDER - NO REWRITES
RewriteCond %{REQUEST_URI} ^/tracker/
RewriteRule .* - [L]

# Redirect index → /
RewriteCond %{THE_REQUEST} \s/+index(\.html|\.php)?[\s?] [NC]
RewriteRule ^index(\.html|\.php)?$ / [R=301,L]

# Remove .html
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]

# Internal .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Internal .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# Security
Options -IndexesRewriteEngine On

# FORCE HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# TRACKER FOLDER - NO REWRITES
RewriteCond %{REQUEST_URI} ^/tracker/
RewriteRule .* - [L]

# Redirect index → /
RewriteCond %{THE_REQUEST} \s/+index(\.html|\.php)?[\s?] [NC]
RewriteRule ^index(\.html|\.php)?$ / [R=301,L]

# Remove .html
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]

# Internal .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Internal .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# Security
Options -Indexes